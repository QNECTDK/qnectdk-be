# Example environment variables for local development.
# Copy this file to .env and fill in the value:
#   cp .env.example .env
#
# The app auto-loads ./.env at startup (spring.config.import in application.yml),
# and docker-compose.yml reads the same value, so one .env covers both.

# MySQL root password (used by the app and by docker-compose)
DB_PASSWORD=change_me

# JWT 서명 시크릿 (HS256, 최소 32바이트). 운영에서는 반드시 교체할 것.
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_bytes_long
# (선택) 토큰 만료 시간 — 생략 시 application.yml 기본값(access 1h, refresh 14d) 사용
# JWT_ACCESS_VALIDITY_MS=3600000
# JWT_REFRESH_VALIDITY_MS=1209600000

# (선택) 프로필 이미지 로컬 저장소 — 생략 시 ./uploads, http://localhost:8080/files 사용
# STORAGE_LOCAL_PATH=./uploads
# STORAGE_BASE_URL=http://localhost:8080/files

# (선택) QR/공유 URL base — 생략 시 https://qnect.app 사용
# SHARE_BASE_URL=https://qnect.app
