# 로컬 개발용 환경변수 — 복사해서 사용: cp .env.example .env
# 앱(spring.config.import)과 docker-compose 가 같은 .env 를 읽는다.
# (.env 는 properties 로 파싱되므로 값 뒤 인라인 주석 금지 — 주석은 줄 단위로만.)

# ── 필수 ──
DB_PASSWORD=change_me
JWT_SECRET=change_me_to_a_random_secret_at_least_32_bytes

# ── 선택 (생략 시 application.yml 기본값) ──
# 토큰 만료(ms): access 1시간 / refresh 14일
# JWT_ACCESS_VALIDITY_MS=3600000
# JWT_REFRESH_VALIDITY_MS=1209600000
# QR/공유 URL base
# SHARE_BASE_URL=https://qnect.app

# ── 선택: AI 퀴즈(Gemini) — 미설정 시 Mock 으로 동작(키 불필요) ──
# 실제 Gemini 사용 시 enabled=true + 키 설정. 키는 서버 전용, 절대 커밋 금지.
# GEMINI_ENABLED=true
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash


