# ===========================================================================
# 데모 데이터 시드 (REST Client) — 배포 버전에서도 그대로 재현용
# 위에서부터 순서대로 실행하면: 친구 상호등록 + 퀴즈 문항수 다양화(3/4/5)
#  + 데모가 완료/부분정답/미응시 섞기 + 오늘 데일리 친구 투표결과 + 메모 까지 채워진다.
#
# ※ 시간/DB 기반이라 이 파일(API)로는 재현 불가한 항목:
#    - 홈 "이 사람을 기억하나요?" 카드: 리마인드는 친구추가 +30일 후 도래(scheduled_at<=now)해야 노출.
#      데모용으로 당장 보이게 하려면 quiz_reminders.scheduled_at 을 과거로 당겨야 함(DB).
#    - QUIZ_REMIND 알림: 위 리마인드가 발송돼야 생김. FRIEND_ADD/DAILY_QUIZ 알림은 아래 흐름/기동시 자동 생성됨.
# ===========================================================================

@baseUrl = http://localhost:8080
@pw = test1234

# --- 데모 본인 + 친구 3명(문항수 3/4/5) ---
@demoId  = demoseed_me
@f1Id    = demoseed_f1
@f2Id    = demoseed_f2
@f3Id    = demoseed_f3

### 회원가입(이미 있으면 409 무시) — 데모
POST {{baseUrl}}/api/auth/signup
Content-Type: application/json

{ "loginId": "{{demoId}}", "phone": "01077770010", "password": "{{pw}}", "name": "시드데모", "birthDate": "2002-04-12" }

### 회원가입 — f1
POST {{baseUrl}}/api/auth/signup
Content-Type: application/json

{ "loginId": "{{f1Id}}", "phone": "01077770011", "password": "{{pw}}", "name": "친구하나", "birthDate": "2002-01-01" }

### 회원가입 — f2
POST {{baseUrl}}/api/auth/signup
Content-Type: application/json

{ "loginId": "{{f2Id}}", "phone": "01077770012", "password": "{{pw}}", "name": "친구둘", "birthDate": "2001-02-02" }

### 회원가입 — f3
POST {{baseUrl}}/api/auth/signup
Content-Type: application/json

{ "loginId": "{{f3Id}}", "phone": "01077770013", "password": "{{pw}}", "name": "친구셋", "birthDate": "2000-03-03" }

### 로그인 — 데모
# @name loginDemo
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{ "loginId": "{{demoId}}", "password": "{{pw}}" }

### 데모 프로필(응시 조건: 완성 필요) — userId 확보
# @name profileDemo
PUT {{baseUrl}}/api/profiles/me
Authorization: Bearer {{loginDemo.response.body.$.data.accessToken}}
Content-Type: application/json

{ "school": "국민대학교", "gender": "MALE", "mbti": "ENFP", "drinkLevel": "소주 2잔", "favoriteFood": "치킨" }

### 데모 관심사
PUT {{baseUrl}}/api/interests/me
Authorization: Bearer {{loginDemo.response.body.$.data.accessToken}}
Content-Type: application/json

{ "interestIds": [1, 2, 11, 21] }

# --- f1 (3문항) ---
### f1 로그인
# @name loginF1
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{ "loginId": "{{f1Id}}", "password": "{{pw}}" }

### f1 프로필 — userId 확보
# @name profileF1
PUT {{baseUrl}}/api/profiles/me
Authorization: Bearer {{loginF1.response.body.$.data.accessToken}}
Content-Type: application/json

{ "school": "연세대학교", "gender": "FEMALE", "mbti": "INFP", "drinkLevel": "맥주 1잔", "favoriteFood": "초밥" }

### f1 퀴즈 저장 (3문항: 음식=치킨 / 아침OX=O / 혈액=A)
PUT {{baseUrl}}/api/quizzes/me
Authorization: Bearer {{loginF1.response.body.$.data.accessToken}}
Content-Type: application/json

{ "questions": [
  { "type": "MULTIPLE", "content": "가장 좋아하는 음식은?", "correctAnswer": "치킨", "required": true,
    "options": [ {"content":"치킨","correct":true}, {"content":"피자","correct":false}, {"content":"초밥","correct":false}, {"content":"파스타","correct":false} ] },
  { "type": "OX", "content": "나는 아침형 인간이다", "correctAnswer": "O", "required": false, "options": [] },
  { "type": "MULTIPLE", "content": "내 혈액형은?", "correctAnswer": "A", "required": false,
    "options": [ {"content":"A","correct":true}, {"content":"B","correct":false}, {"content":"O","correct":false}, {"content":"AB","correct":false} ] }
] }

# --- f2 (4문항) ---
### f2 로그인
# @name loginF2
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{ "loginId": "{{f2Id}}", "password": "{{pw}}" }

### f2 프로필
# @name profileF2
PUT {{baseUrl}}/api/profiles/me
Authorization: Bearer {{loginF2.response.body.$.data.accessToken}}
Content-Type: application/json

{ "school": "고려대학교", "gender": "MALE", "mbti": "ENTP", "drinkLevel": "소주 1병", "favoriteFood": "삼겹살" }

### f2 퀴즈 저장 (4문항: +운동OX=O)
PUT {{baseUrl}}/api/quizzes/me
Authorization: Bearer {{loginF2.response.body.$.data.accessToken}}
Content-Type: application/json

{ "questions": [
  { "type": "MULTIPLE", "content": "가장 좋아하는 음식은?", "correctAnswer": "치킨", "required": true,
    "options": [ {"content":"치킨","correct":true}, {"content":"피자","correct":false}, {"content":"초밥","correct":false}, {"content":"파스타","correct":false} ] },
  { "type": "OX", "content": "나는 아침형 인간이다", "correctAnswer": "O", "required": false, "options": [] },
  { "type": "MULTIPLE", "content": "내 혈액형은?", "correctAnswer": "A", "required": false,
    "options": [ {"content":"A","correct":true}, {"content":"B","correct":false}, {"content":"O","correct":false}, {"content":"AB","correct":false} ] },
  { "type": "OX", "content": "나는 운동을 좋아한다", "correctAnswer": "O", "required": false, "options": [] }
] }

# --- f3 (5문항) ---
### f3 로그인
# @name loginF3
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{ "loginId": "{{f3Id}}", "password": "{{pw}}" }

### f3 프로필
# @name profileF3
PUT {{baseUrl}}/api/profiles/me
Authorization: Bearer {{loginF3.response.body.$.data.accessToken}}
Content-Type: application/json

{ "school": "성균관대학교", "gender": "FEMALE", "mbti": "ISFJ", "drinkLevel": "안 마심", "favoriteFood": "파스타" }

### f3 퀴즈 저장 (5문항: +계절=여름)
PUT {{baseUrl}}/api/quizzes/me
Authorization: Bearer {{loginF3.response.body.$.data.accessToken}}
Content-Type: application/json

{ "questions": [
  { "type": "MULTIPLE", "content": "가장 좋아하는 음식은?", "correctAnswer": "치킨", "required": true,
    "options": [ {"content":"치킨","correct":true}, {"content":"피자","correct":false}, {"content":"초밥","correct":false}, {"content":"파스타","correct":false} ] },
  { "type": "OX", "content": "나는 아침형 인간이다", "correctAnswer": "O", "required": false, "options": [] },
  { "type": "MULTIPLE", "content": "내 혈액형은?", "correctAnswer": "A", "required": false,
    "options": [ {"content":"A","correct":true}, {"content":"B","correct":false}, {"content":"O","correct":false}, {"content":"AB","correct":false} ] },
  { "type": "OX", "content": "나는 운동을 좋아한다", "correctAnswer": "O", "required": false, "options": [] },
  { "type": "MULTIPLE", "content": "좋아하는 계절은?", "correctAnswer": "여름", "required": false,
    "options": [ {"content":"봄","correct":false}, {"content":"여름","correct":true}, {"content":"가을","correct":false}, {"content":"겨울","correct":false} ] }
] }

# --- 데모가 친구 3명을 모두 추가(수락=상호등록) ---
### 데모 → f1 추가
POST {{baseUrl}}/api/friends
Authorization: Bearer {{loginDemo.response.body.$.data.accessToken}}
Content-Type: application/json

{ "friendId": {{profileF1.response.body.$.data.userId}} }

### 데모 → f2 추가
POST {{baseUrl}}/api/friends
Authorization: Bearer {{loginDemo.response.body.$.data.accessToken}}
Content-Type: application/json

{ "friendId": {{profileF2.response.body.$.data.userId}} }

### 데모 → f3 추가
POST {{baseUrl}}/api/friends
Authorization: Bearer {{loginDemo.response.body.$.data.accessToken}}
Content-Type: application/json

{ "friendId": {{profileF3.response.body.$.data.userId}} }

# --- 데모 응시: f1=완료(3/3), f2=부분(2/4), f3=미응시 ---
### f1 퀴즈 풀이화면 조회(문항 id 확보)
# @name solvableF1
GET {{baseUrl}}/api/quizzes/owner/{{profileF1.response.body.$.data.userId}}
Authorization: Bearer {{loginDemo.response.body.$.data.accessToken}}

### f1 응시 — 전부 정답(3/3, 완료)
POST {{baseUrl}}/api/quizzes/owner/{{profileF1.response.body.$.data.userId}}/attempts
Authorization: Bearer {{loginDemo.response.body.$.data.accessToken}}
Content-Type: application/json

{ "answers": [
  { "questionId": {{solvableF1.response.body.$.data.questions[0].questionId}}, "answer": "치킨" },
  { "questionId": {{solvableF1.response.body.$.data.questions[1].questionId}}, "answer": "O" },
  { "questionId": {{solvableF1.response.body.$.data.questions[2].questionId}}, "answer": "A" }
] }

### f2 퀴즈 풀이화면 조회
# @name solvableF2
GET {{baseUrl}}/api/quizzes/owner/{{profileF2.response.body.$.data.userId}}
Authorization: Bearer {{loginDemo.response.body.$.data.accessToken}}

### f2 응시 — 앞 2개만 정답, 뒤 2개 오답(2/4, 부분 정답)
POST {{baseUrl}}/api/quizzes/owner/{{profileF2.response.body.$.data.userId}}/attempts
Authorization: Bearer {{loginDemo.response.body.$.data.accessToken}}
Content-Type: application/json

{ "answers": [
  { "questionId": {{solvableF2.response.body.$.data.questions[0].questionId}}, "answer": "치킨" },
  { "questionId": {{solvableF2.response.body.$.data.questions[1].questionId}}, "answer": "O" },
  { "questionId": {{solvableF2.response.body.$.data.questions[2].questionId}}, "answer": "오답" },
  { "questionId": {{solvableF2.response.body.$.data.questions[3].questionId}}, "answer": "오답" }
] }

# (f3 는 일부러 미응시 → 퀴즈 목록에서 "퀴즈 풀기" 상태로 남음)

# --- 오늘 데일리: 데모 + 친구 3명 답변(친구 투표결과 채우기) ---
### 데모 데일리 답변 A (이미 답했으면 409 무시)
POST {{baseUrl}}/api/daily/today/answer
Authorization: Bearer {{loginDemo.response.body.$.data.accessToken}}
Content-Type: application/json

{ "selected": "A" }

### f1 데일리 A
POST {{baseUrl}}/api/daily/today/answer
Authorization: Bearer {{loginF1.response.body.$.data.accessToken}}
Content-Type: application/json

{ "selected": "A" }

### f2 데일리 B
POST {{baseUrl}}/api/daily/today/answer
Authorization: Bearer {{loginF2.response.body.$.data.accessToken}}
Content-Type: application/json

{ "selected": "B" }

### f3 데일리 A
POST {{baseUrl}}/api/daily/today/answer
Authorization: Bearer {{loginF3.response.body.$.data.accessToken}}
Content-Type: application/json

{ "selected": "A" }

### 데모: 오늘 데일리 통계(친구 투표 결과) 확인 — overall + friends.selections
GET {{baseUrl}}/api/daily/today/stats
Authorization: Bearer {{loginDemo.response.body.$.data.accessToken}}

# --- 메모 ---
### 데모 → f1 메모
PUT {{baseUrl}}/api/friends/memos
Authorization: Bearer {{loginDemo.response.body.$.data.accessToken}}
Content-Type: application/json

{ "friendId": {{profileF1.response.body.$.data.userId}}, "content": "동아리에서 만난 친구. 기타 잘 침" }

### 데모: 친구 퀴즈 목록 확인 — f1 완료(3/3) / f2 완료(2/4) / f3 미응시 가 보여야 함
GET {{baseUrl}}/api/quizzes/friends
Authorization: Bearer {{loginDemo.response.body.$.data.accessToken}}
