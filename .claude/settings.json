{
  "permissions": {
    "allow": [
      "Bash(./gradlew compileJava:*)",
      "Bash(./gradlew compileTestJava:*)",
      "Bash(./gradlew build:*)",
      "Bash(./gradlew test:*)",
      "Bash(./gradlew bootRun:*)",
      "Bash(docker compose up:*)",
      "Bash(docker compose down)",
      "Bash(docker compose logs:*)",
      "Bash(docker compose ps:*)"
    ],
    "deny": [
      "Bash(docker compose down -v:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/block-commit.sh\"",
            "timeout": 15,
            "statusMessage": "커밋 규칙 확인 중"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/convention-check.sh\"",
            "timeout": 15,
            "statusMessage": "컨벤션 점검 중"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/compile-check.sh\"",
            "timeout": 180,
            "statusMessage": "컴파일 점검 중"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/integrity-check.sh\"",
            "timeout": 240,
            "statusMessage": "전체 컴파일 정합성 점검 중"
          }
        ]
      }
    ]
  }
}
