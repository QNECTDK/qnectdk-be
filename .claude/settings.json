{
  "permissions": {
    "allow": [
      "Bash(./gradlew compileJava:*)",
      "Bash(./gradlew compileTestJava:*)",
      "Bash(./gradlew build:*)",
      "Bash(./gradlew test:*)",
      "Bash(./gradlew bootRun:*)",
      "Bash(docker compose up:*)",
      "Bash(docker compose down)",
      "Bash(docker compose logs:*)",
      "Bash(docker compose ps:*)"
    ],
    "deny": [
      "Bash(docker compose down -v:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/block-commit.sh\"",
            "timeout": 15,
            "statusMessage": "커밋 규칙 확인 중"
          }
        ]
      }
    ]
  }
}
