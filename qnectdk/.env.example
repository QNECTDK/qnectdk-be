# Example environment variables for local development
# Copy this file to .env or set the variables in your OS/CI before running the app.

# MySQL datasource (change database, host, port, and params as needed)
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/qnectdk?useSSL=false&serverTimezone=UTC&characterEncoding=UTF-8
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=change_me
SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver

# JPA / Hibernate
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_FORMAT_SQL=true

# Server
SERVER_PORT=8080

# Optional: active Spring profile (dev / prod / test)
SPRING_PROFILES_ACTIVE=dev

# Notes:
# - Spring Boot reads environment variables automatically, so you can set these in your shell/CI.
# - If you prefer a .env file to be automatically loaded at runtime, add a library like "io.github.cdimascio:java-dotenv" or configure your IDE/launcher to load the file into the process environment.

