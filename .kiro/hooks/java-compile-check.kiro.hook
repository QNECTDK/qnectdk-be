{
  "enabled": true,
  "name": "Compile Check on Java Save",
  "description": "자바 파일 저장 시 ./gradlew compileJava로 컴파일을 점검한다 (DB 불필요).",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "*.java"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "gradlew.bat compileJava -q --console=plain",
    "timeout": 180
  }
}