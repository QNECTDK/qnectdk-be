{
  "enabled": true,
  "name": "Compile Check (Manual)",
  "description": "수동 실행 시 gradlew compileJava로 컴파일을 점검한다 (DB 불필요). 파일 저장마다 자동 실행하지 않는다.",
  "version": "2",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "runCommand",
    "command": "cmd /c gradlew.bat compileJava -q --console=plain",
    "timeout": 180
  }
}
